# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP Configuration for sending actual emails from forms:
# SMTP_HOST: The hostname of your SMTP server (e.g. smtp.gmail.com, mail.smtp2go.com, smtp.sendgrid.net)
SMTP_HOST=
# SMTP_PORT: Port number (usually 587 for TLS, 465 for SSL, or 25)
SMTP_PORT=
# SMTP_USER: SMTP account username (e.g. your email address or api key name)
SMTP_USER=
# SMTP_PASS: SMTP password (or App Password for Gmail/Google Workspace users)
SMTP_PASS=
# SMTP_FROM_EMAIL: Friendly sender email address (should be verified in your SMTP provider)
SMTP_FROM_EMAIL=
# EMAIL_RECEIVER: Form notifications receiver email (Defaults to mwalker@marketni.co)
EMAIL_RECEIVER=

